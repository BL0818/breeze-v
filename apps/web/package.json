{
  "name": "@breezev/web",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "vite dev",
    "lint": "eslint \"src/**/*.{ts,vue}\" --max-warnings=0",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "preview": "vite preview",
    "e2e:install": "playwright install chromium",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@breezev/types": "workspace:*",
    "@breezev/ui": "workspace:*",
    "@breezev/utils": "workspace:*",
    "@vue/server-renderer": "3.5.13",
    "@vueuse/motion": "^3.0.3",
    "pinia": "3.0.1",
    "radix-vue": "^1.9.11",
    "vee-validate": "^4.15.0",
    "vue": "3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@unocss/reset": "^66.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "unocss": "^66.1.0",
    "vite": "6.4.1",
    "vitest": "^2.1.8"
  }
}
